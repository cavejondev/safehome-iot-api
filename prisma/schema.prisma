// Schema principal do banco relacional do SafeHome.
// Ele modela usuarios, residencias, sensores, botoes de ajuda, eventos e alertas.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanTier {
  FREE
  CARE
  PREMIUM
}

enum HouseholdRole {
  OWNER
  CAREGIVER
  VIEWER
}

enum DeviceComponentType {
  GATEWAY
  SENSOR
  HELP_BUTTON
}

enum AlertType {
  HELP_REQUEST
  SENSOR_OFFLINE
  BUTTON_OFFLINE
  SYSTEM_FAILURE
  INACTIVITY
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum AlertSubjectType {
  GATEWAY
  SENSOR
  HELP_BUTTON
  HOUSEHOLD
}

model User {
  id           String            @id @default(cuid())
  fullName     String
  email        String            @unique
  passwordHash String
  phone        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  HouseholdMember[]
  acknowledged Alert[]           @relation("AlertAcknowledgedBy")
}

model Household {
  id           String             @id @default(cuid())
  name         String
  residentName String
  addressLabel String?
  plan         PlanTier           @default(CARE)
  timezone     String             @default("America/Sao_Paulo")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  members      HouseholdMember[]
  settings     HouseholdSettings?
  gateways     Gateway[]
  sensors      Sensor[]
  helpButtons  HelpButton[]
  sensorEvents SensorEvent[]
  helpEvents   HelpButtonEvent[]
  alerts       Alert[]
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  userId      String
  role        HouseholdRole @default(VIEWER)
  createdAt   DateTime      @default(now())
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
}

model HouseholdSettings {
  id                         String    @id @default(cuid())
  householdId                String    @unique
  inactivityThresholdMinutes Int       @default(120)
  sensorCheckIntervalMinutes Int       @default(30)
  buttonCheckIntervalMinutes Int       @default(10)
  sleepModeStart             String?
  sleepModeEnd               String?
  quietHoursEnabled          Boolean   @default(false)
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  household                  Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model Gateway {
  id              String            @id @default(cuid())
  householdId     String
  name            String
  serialNumber    String            @unique
  tokenHash       String            @unique
  firmwareVersion String?
  isActive        Boolean           @default(true)
  lastSeenAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  household       Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  sensors         Sensor[]
  helpButtons     HelpButton[]
  heartbeats      DeviceHeartbeat[]
}

model Sensor {
  id              String        @id @default(cuid())
  householdId     String
  gatewayId       String
  name            String
  externalId      String
  locationLabel   String?
  isActive        Boolean       @default(true)
  lastSeenAt      DateTime?
  lastTriggeredAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  household       Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  gateway         Gateway       @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  events          SensorEvent[]

  @@unique([gatewayId, externalId])
}

model HelpButton {
  id            String            @id @default(cuid())
  householdId   String
  gatewayId     String
  name          String
  externalId    String
  locationLabel String?
  isActive      Boolean           @default(true)
  lastSeenAt    DateTime?
  lastPressedAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  household     Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  gateway       Gateway           @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  events        HelpButtonEvent[]

  @@unique([gatewayId, externalId])
}

model SensorEvent {
  id            String    @id @default(cuid())
  householdId   String
  sensorId      String
  detectedAt    DateTime  @default(now())
  sourceEventId String?
  metadata      Json?
  household     Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  sensor        Sensor    @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  @@index([householdId, detectedAt])
  @@unique([sensorId, sourceEventId])
}

model HelpButtonEvent {
  id            String     @id @default(cuid())
  householdId   String
  helpButtonId  String
  triggeredAt   DateTime   @default(now())
  sourceEventId String?
  metadata      Json?
  household     Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  helpButton    HelpButton @relation(fields: [helpButtonId], references: [id], onDelete: Cascade)

  @@index([householdId, triggeredAt])
  @@unique([helpButtonId, sourceEventId])
}

model DeviceHeartbeat {
  id            String              @id @default(cuid())
  gatewayId     String
  componentType DeviceComponentType
  componentId   String?
  receivedAt    DateTime            @default(now())
  metadata      Json?
  gateway       Gateway             @relation(fields: [gatewayId], references: [id], onDelete: Cascade)

  @@index([gatewayId, receivedAt])
  @@index([componentType, componentId])
}

model Alert {
  id               String            @id @default(cuid())
  householdId      String
  type             AlertType
  severity         AlertSeverity
  status           AlertStatus       @default(OPEN)
  title            String
  description      String
  subjectType      AlertSubjectType?
  subjectId        String?
  metadata         Json?
  acknowledgedById String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?
  household        Household         @relation(fields: [householdId], references: [id], onDelete: Cascade)
  acknowledgedBy   User?             @relation("AlertAcknowledgedBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  @@index([householdId, status, createdAt])
  @@index([type, status])
}
