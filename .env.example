# Ambiente da aplicacao.
NODE_ENV=development
PORT=3333
APP_TIMEZONE=America/Sao_Paulo
CORS_ORIGIN=http://localhost:19006

# Banco relacional PostgreSQL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/safehome

# Seguranca da API.
JWT_SECRET=troque-esta-chave-por-uma-chave-forte-com-32-caracteres
JWT_EXPIRES_IN=12h

# Scheduler de monitoramento.
MONITORING_ENABLED=true
MONITORING_CRON=*/5 * * * *
DEFAULT_SENSOR_CHECK_MINUTES=30
DEFAULT_BUTTON_CHECK_MINUTES=10
DEFAULT_INACTIVITY_THRESHOLD_MINUTES=120
